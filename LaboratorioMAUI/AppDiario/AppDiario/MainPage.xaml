<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppDiario.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <Label Text="Il mio diario"
                   FontSize="24"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   />
            <Entry x:Name="entTitolo" Placeholder="Inserisci Titolo"/>
            <Entry x:Name="entTesto" Placeholder="Inserisci Testo"/>
            <Button x:Name="btSalva" 
                    Text="Salva nota" 
                    BackgroundColor="Green"
                    TextColor="White"
                    Clicked="OnSalva_Clicked"/>
            <Button x:Name="btLeggi" 
                    Text="Leggi tutte le note" 
                    BackgroundColor="Gray"
                    TextColor="White"
                    Clicked="OnLeggi_Clicked"/>
            <BoxView HeightRequest="1" Color="Silver"/>
            <Label Text="Note Salvate nel file:" FontAttributes="Italic"/>
            <Editor x:Name="editDisplay"
                    HeightRequest="300"
                    IsReadOnly="True"
                    Background="GhostWhite"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
